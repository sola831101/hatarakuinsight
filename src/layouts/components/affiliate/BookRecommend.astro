---
interface Props {
  title: string;
  author: string;
  description: string;
  amazonUrl: string;
  imageUrl?: string;
}

const { title, author, description, amazonUrl, imageUrl } = Astro.props;
---

<div class="my-6 p-4 border border-slate-200 rounded-lg flex gap-4 bg-white">
  <p class="text-xs font-semibold text-slate-400 absolute -mt-3 bg-white px-1">PR</p>
  {imageUrl && (
    <img src={imageUrl} alt={title} class="w-16 h-auto object-contain shrink-0" loading="lazy" />
  )}
  <div>
    <p class="text-xs text-slate-500 mb-1">{author}</p>
    <p class="font-bold text-sm text-slate-800 mb-1">{title}</p>
    <p class="text-xs text-slate-600 mb-2 leading-relaxed">{description}</p>
    <a
      href={amazonUrl}
      rel="nofollow noopener"
      target="_blank"
      class="inline-block bg-orange-400 text-white font-bold text-xs py-1.5 px-4 rounded no-underline hover:bg-orange-500 transition-colors"
    >
      Amazonで見る
    </a>
  </div>
</div>
