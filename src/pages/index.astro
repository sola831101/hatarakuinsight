---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 9);

const categoryLabels: Record<string, string> = {
  tenshoku: '転職',
  saiyo: '採用',
  nenshu: '年収',
  career: 'キャリア',
  hatarakikata: '働き方',
  shinsotsu: '新卒採用',
  koyo: '雇用',
  worklife: 'ワークライフバランス',
};
---

<BaseLayout
  title="はたらくインサイト"
  description="転職・採用・年収・働き方のデータを独自分析。統計と現場感覚をもとに、仕事と人材の「今」をわかりやすく届けます。"
>
  <!-- ヒーロー -->
  <section class="bg-gradient-to-b from-blue-700 to-blue-600 text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">
        転職・採用・年収・働き方の<br class="hidden md:block" />データを深く読む
      </h1>
      <p class="text-blue-100 text-base md:text-lg leading-relaxed max-w-xl mx-auto">
        統計データとニュースをもとに独自分析。<br />
        人材・仕事の「今」をやさしく・わかりやすく届けます。
      </p>
    </div>
  </section>

  <!-- カテゴリリンク -->
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { key: 'tenshoku', icon: '🔄', label: '転職' },
        { key: 'saiyo', icon: '🏢', label: '採用' },
        { key: 'nenshu', icon: '💰', label: '年収' },
        { key: 'career', icon: '📈', label: 'キャリア' },
        { key: 'hatarakikata', icon: '⚖️', label: '働き方' },
        { key: 'shinsotsu', icon: '🎓', label: '新卒採用' },
        { key: 'koyo', icon: '📊', label: '雇用' },
        { key: 'worklife', icon: '🌿', label: 'ワークライフ' },
      ].map(cat => (
        <a
          href={`/category/${cat.key}`}
          class="flex flex-col items-center justify-center gap-1.5 py-4 bg-white border border-slate-200 rounded-xl no-underline hover:border-blue-300 hover:shadow-sm transition-all"
        >
          <span class="text-2xl">{cat.icon}</span>
          <span class="text-sm font-semibold text-slate-700">{cat.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- 最新記事 -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
      <span class="w-1 h-6 bg-blue-600 rounded-full inline-block"></span>
      最新記事
    </h2>

    {articles.length === 0 ? (
      <p class="text-slate-500 text-center py-12">記事を準備中です。しばらくお待ちください。</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {articles.map(article => (
          <a
            href={`/articles/${article.slug}`}
            class="bg-white border border-slate-200 rounded-xl overflow-hidden no-underline hover:shadow-md hover:border-blue-200 transition-all group"
          >
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs bg-blue-100 text-blue-700 font-semibold px-2 py-0.5 rounded-full">
                  {categoryLabels[article.data.category] ?? article.data.category}
                </span>
              </div>
              <h3 class="font-bold text-slate-800 text-sm leading-snug mb-3 group-hover:text-blue-700 transition-colors">
                {article.data.title}
              </h3>
              <p class="text-xs text-slate-400">
                {article.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
              </p>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="text-center mt-8">
      <a
        href="/articles"
        class="inline-block border border-blue-600 text-blue-700 font-semibold text-sm px-8 py-3 rounded-full no-underline hover:bg-blue-600 hover:text-white transition-colors"
      >
        記事一覧を見る
      </a>
    </div>
  </section>
</BaseLayout>
